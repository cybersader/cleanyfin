# cleanyfin — copy to .env and adjust. Sensible defaults mean you can also just
# run `docker compose up -d --build` with no .env at all.
#
# Host port the API is published on (container always listens on 8080).
CLEANYFIN_PORT=8080

# CORS origin allowed to call the API (the marking PWA runs on a separate
# origin). Default "*" for dev; set to your PWA's origin in production.
# CLEANYFIN_CORS_ORIGIN=*

# Backup is trivial: the entire dataset is one SQLite file inside the
# `cleanyfin-data` docker volume. Copy it to back up; restore by copying back.
